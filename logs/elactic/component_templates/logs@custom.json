{
  "properties": {
    "log": {
      "properties": {
        "logger": {
          "ignore_above": 1024,
          "type": "keyword"
        }
      }
    },
    "event": {
      "properties": {
        "action": {
          "ignore_above": 1024,
          "type": "keyword"
        },
        "outcome": {
          "ignore_above": 1024,
          "type": "keyword"
        }
      }
    },
    "error": {
      "properties": {
        "stack_trace": {
          "type": "wildcard",
          "fields": {
            "text": {
              "type": "match_only_text"
            }
          }
        },
        "type": {
          "ignore_above": 1024,
          "type": "keyword"
        },
        "message": {
          "type": "match_only_text"
        }
      }
    }
  }
}